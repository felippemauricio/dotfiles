# Homebrew (Apple Silicon)

eval "$(/opt/homebrew/bin/brew shellenv)"

# ===================================================================================

# nvm — Node Version Manager

export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && . "/opt/homebrew/opt/nvm/nvm.sh"
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && . "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"

# Automatically switch to the version in .nvmrc when entering a directory.
# Guarded for zsh: `scripts/languages.sh` sources this file under bash to load
# nvm/pyenv, and `autoload`/`add-zsh-hook` are zsh builtins that error there.
if [ -n "$ZSH_VERSION" ]; then
  autoload -U add-zsh-hook
  load-nvmrc() {
    if [[ -f .nvmrc && -r .nvmrc ]]; then
      nvm use
    elif [[ $(nvm version) != $(nvm version default) ]]; then
      local default_version=$(nvm version default 2>/dev/null)
      if [[ "$default_version" != "N/A" ]]; then
        echo "Reverting to nvm default version"
        nvm use default
      fi
    fi
  }
  add-zsh-hook chpwd load-nvmrc
  load-nvmrc
fi

# ===================================================================================

# pyenv — Python Version Manager

export PYENV_ROOT="$HOME/.pyenv"
[[ -d $PYENV_ROOT/bin ]] && export PATH="$PYENV_ROOT/bin:$PATH"
if command -v pyenv 1>/dev/null 2>&1; then
  eval "$(pyenv init -)"
fi

# ===================================================================================

# Open the workspace folder on a new shell

cd ~/Workspace

# ===================================================================================

# Aliases

# Muscle memory from the_silver_searcher (unmaintained) — ripgrep replaces it.
alias ag='rg'

# ===================================================================================

# Claude Code inside tmux with one command. Bare `claudio` starts a FRESH,
# isolated tmux session for the current directory every time (`claude-<dir>-N`),
# so several in the same folder never share a view. `claudio <name>` opens (or
# reattaches to) a named session instead. Inside a tmux session it just runs claude.

claudio() {
  if [ -n "${TMUX-}" ]; then
    claude "$@"
    return
  fi
  local dir_slug="${${PWD:t}//[^a-zA-Z0-9-]/-}"
  if [ $# -gt 0 ]; then
    local name="claude-$1"; shift
    tmux new-session -A -s "$name" -c "$PWD" claude "$@"
  else
    local n=1
    while tmux has-session -t "claude-${dir_slug}-${n}" 2>/dev/null; do
      n=$((n + 1))
    done
    tmux new-session -s "claude-${dir_slug}-${n}" -c "$PWD" claude
  fi
}
